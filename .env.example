# Copy this file to ~/.postmind/.env and fill in your values.
# Do NOT place this file inside the repo with real values.

# Required for AI features (triage, bulk, avoid, digest, rules --add)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Optional overrides
POSTMIND_AI_MODEL=claude-sonnet-4-6
POSTMIND_DRY_RUN=false
POSTMIND_UNDO_WINDOW_DAYS=30
